# aiagent makeself startup script (body; prepended at build time with
# #!/bin/sh + AIAGENT_VERSION= + PYVER=).
#
# makeself (built with --nox11 --nocomp) extracts this dir to a temp location and
# runs this script from there. The dir contains:
#   ./zstd            a bundled STATIC zstd (so the target needs no zstd)
#   ./bundle.tar.zst  the zstd-compressed CPython + aiagent + deps tree
#
# We decompress with the bundled zstd, then lay the tree into an install prefix
# and expose `aiagent`. Install prefix resolution (highest first):
#   1. `--target DIR`  (pass as: sh aiagent-install.sh -- --target DIR)
#   2. $AIAGENT_PREFIX
#   3. $HOME/.local
set -eu

PREFIX="${AIAGENT_PREFIX:-$HOME/.local}"
while [ $# -gt 0 ]; do
  case "$1" in
    --target) PREFIX="$2"; shift 2 ;;
    --target=*) PREFIX="${1#*=}"; shift ;;
    -h|--help)
      echo "aiagent ${AIAGENT_VERSION} installer"
      echo "Usage: sh aiagent-install.sh [-- --target DIR]   (or set AIAGENT_PREFIX)"
      exit 0 ;;
    *) shift ;;
  esac
done

here="$(pwd)"                       # makeself extraction dir (zstd + bundle.tar.zst)
chmod +x "$here/zstd" 2>/dev/null || true

mkdir -p "$PREFIX"
PREFIX="$(CDPATH= cd -- "$PREFIX" && pwd)"
LIB="$PREFIX/lib/aiagent"
BINDIR="$PREFIX/bin"
DOCDIR="$PREFIX/share/doc/aiagent"

echo "Installing aiagent ${AIAGENT_VERSION} -> $PREFIX"

# Decompress the heavy payload with the BUNDLED static zstd (target needs none).
# Stage on the SAME filesystem as the target for a fast rename.
stage="$PREFIX/.aiagent-install.$$"
rm -rf "$stage"; mkdir -p "$stage"
trap 'rm -rf "$stage"' EXIT INT TERM
"$here/zstd" -dc "$here/bundle.tar.zst" | tar -xf - -C "$stage"   # -> stage/python, stage/doc

mkdir -p "$BINDIR" "$PREFIX/lib" "$PREFIX/share/doc"
rm -rf "$LIB"; mv "$stage/python" "$LIB"
if [ -d "$stage/doc" ]; then rm -rf "$DOCDIR"; mv "$stage/doc" "$DOCDIR"; fi

# The bundled interpreter every console script resolves to. `-s` makes the bundle
# hermetic (ignores the host user site). A shebang over the kernel's 127-byte
# limit can't be exec'd, so fail fast on an over-long prefix.
BUNDLE_PY="$LIB/bin/python$PYVER"
shebang="#!$BUNDLE_PY -s"
if [ ${#shebang} -gt 127 ]; then
  echo "error: install path too long — shebang '$shebang' is ${#shebang} bytes" >&2
  echo "       (kernel limit 127). Re-run with a shorter AIAGENT_PREFIX/--target." >&2
  exit 1
fi

# Repoint console-script shebangs (pip stamped a build-time path) at the bundled
# interpreter on THIS machine. grep -I skips the interpreter binary.
for f in "$LIB"/bin/*; do
  [ -f "$f" ] || continue
  grep -Iqm1 '^#!.*python' "$f" 2>/dev/null || continue
  tmp="$f.aiagent-fix.$$"
  { printf '%s\n' "$shebang"; tail -n +2 "$f"; } > "$tmp"
  chmod 755 "$tmp"; mv "$tmp" "$f"
done

ln -sf "$LIB/bin/python$PYVER" "$BINDIR/python$PYVER"
ln -sf "$LIB/bin/aiagent"      "$BINDIR/aiagent"

echo "Installed:"
echo "  $BINDIR/aiagent      ->  $LIB/bin/aiagent  (Python console script)"
echo "  $BINDIR/python$PYVER   ->  bundled interpreter"
echo "  $LIB/  (CPython $PYVER + aiagent + deps, sourceless precompiled)"
case ":${PATH}:" in
  *":$BINDIR:"*) echo "Run: aiagent --help" ;;
  *) echo "Add $BINDIR to PATH:  export PATH=\"$BINDIR:\$PATH\"" ;;
esac
